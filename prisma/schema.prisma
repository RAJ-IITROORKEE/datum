// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkId     String   @unique
  name        String
  email       String   @unique
  phone       String?
  profession  String?
  isLoggedIn  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}

enum ContactStatus {
  PENDING
  RESOLVED
  DELETED
}

enum ConversationType {
  NEW_INQUIRY
  ADMIN_REPLY
  USER_REPLY
}

enum AgentStatus {
  ONLINE
  OFFLINE
}

enum CommandJobStatus {
  PENDING
  SENT
  SUCCEEDED
  FAILED
  TIMEOUT
}

model ContactUs {
  id               String           @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  email            String
  subject          String
  message          String
  status           ContactStatus    @default(PENDING)

  // Thread management
  threadId         String?
  parentId         String?          @db.ObjectId
  conversationType ConversationType @default(NEW_INQUIRY)

  // Rate limiting
  dailyMessageCount Int             @default(0)
  lastMessageDate   DateTime?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Self-referential relation for threading
  parent           ContactUs?       @relation("ContactThread", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies          ContactUs[]      @relation("ContactThread")

  @@map("contact_us")
  @@index([threadId])
  @@index([email])
}

model Newsletter {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("newsletters")
}

model AdminSurvey {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  firmsName             String
  founderPrincipal      String
  yearOfEstablishment   Int?
  websiteLink           String?
  officeAddress         String
  contactNumber         String
  state                 String
  city                  String
  email                 String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("admin_surveys")
  @@index([state])
  @@index([city])
  @@index([yearOfEstablishment])
}

// Copilot Chat Models
model ChatConversation {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String
  title      String   @default("New Chat")
  model      String   @default("anthropic/claude-sonnet-4.5")
  isArchived Boolean  @default(false)
  tags       String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages   ChatMessage[]

  @@map("chat_conversations")
  @@index([userId])
  @@index([userId, isArchived])
}

model ChatMessage {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String   @db.ObjectId
  role           String   // 'user' or 'assistant'
  content        String
  createdAt      DateTime @default(now())

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
  @@index([conversationId])
}

model RevitAgentPairing {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkUserId String
  code        String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  @@map("revit_agent_pairings")
  @@index([clerkUserId])
  @@index([expiresAt])
}

model RevitAgentSession {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  clerkUserId  String
  tokenHash    String      @unique
  deviceName   String?
  os           String?
  agentVersion String?
  status       AgentStatus @default(ONLINE)
  lastSeenAt   DateTime    @default(now())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  jobs         RevitCommandJob[]

  @@map("revit_agent_sessions")
  @@index([clerkUserId])
  @@index([lastSeenAt])
}

model RevitCommandJob {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  clerkUserId    String
  agentSessionId String?          @db.ObjectId
  commandName    String
  payload        Json
  status         CommandJobStatus @default(PENDING)
  result         Json?
  error          String?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  agentSession   RevitAgentSession? @relation(fields: [agentSessionId], references: [id], onDelete: SetNull)

  @@map("revit_command_jobs")
  @@index([clerkUserId, status])
  @@index([agentSessionId])
  @@index([createdAt])
}

model RevitRelayToken {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkUserId String   @unique // One active token per user
  token       String
  relayUrl    String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("revit_relay_tokens")
  @@index([expiresAt])
}
